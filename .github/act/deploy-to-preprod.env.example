# Environment for testing the deploy-to-preprod workflow locally with act.
#
# Usage:
#   cp .github/act/deploy-to-preprod.env.example .github/act/deploy-to-preprod.env
#   # Fill in all values below, then:
#   make test-ci-deploy-to-preprod
#
# The Makefile target passes dry_run=true, which selects the dry-run job in the
# workflow:
#   - No images are pushed to GHCR or Artifact Registry.
#   - No Cloud Run deployment is performed.
# A dry-run summary is printed to the job summary instead.
#
# The dry-run job still authenticates (the auth action verifies local gcloud
# credentials when running under act). To run with dry_run=false locally you must
# already be authenticated to Google Cloud — auth will fail otherwise.
#
# This file is passed as both --secret-file (for GITHUB_TOKEN) and --var-file
# (for GCLOUD_* vars that map to ${{ vars.X }} in the workflow).
#
# GITHUB_TOKEN: Generate at https://github.com/settings/tokens — scope: read:packages
GITHUB_TOKEN=

# Google Cloud configuration — maps to ${{ vars.GCLOUD_* }} in the workflow
GCLOUD_IDENTITY_PROVIDER=projects/<project-number>/locations/global/workloadIdentityPools/<pool>/providers/<provider>
GCLOUD_PROJECT_ID=<gcp-project-id>
GCLOUD_REGION=europe-west1
GCLOUD_SERVICE_ACCOUNT=<service-account>@<project>.iam.gserviceaccount.com
ENVIRONMENT=PREPROD
GCLOUD_RUN_SERVICE=<cloud-run-service-name>
GCLOUD_SECRET_TELEGRAM_APITOKEN_VERSION=projects/<project-id>/secrets/<secret-name>/versions/latest
