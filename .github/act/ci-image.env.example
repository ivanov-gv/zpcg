# Environment for testing the ci-image workflow locally with act.
#
# Usage:
#   cp .github/act/ci-image.env.example .github/act/ci-image.env
#   # Set GITHUB_TOKEN below, then:
#   make test-ci-ci-image
#
# The Makefile target passes dry_run=true and act sets ACT=true, so:
#   - The Docker build runs locally (TDLib compilation, ~15 min).
#   - No image is pushed to GHCR.
# The dry-run action detects act and enforces dry-run mode.
#
# GITHUB_TOKEN: optional for local dry-run, required if you ever run this workflow
# outside enforced act dry-run and push to GHCR.
# Generate at https://github.com/settings/tokens — required scope: write:packages
GITHUB_TOKEN=

# TDLIB_COMMIT: maps to ${{ vars.TDLIB_COMMIT }} in the workflow. Used as the
# docker build-arg and in the tdlib-<commit> image tag. In real CI this is a
# repository variable set under Settings → Secrets and variables → Actions → Variables.
TDLIB_COMMIT=971684a
