# Environment for testing the ci-image workflow locally with act.
#
# Usage:
#   cp .github/act/ci-image.env.example .github/act/ci-image.env
#   # Set GITHUB_TOKEN below, then:
#   make test-ci-ci-image
#
# The Makefile target passes dry_run=true, which selects the dry-run job in the
# workflow:
#   - The image is built locally (load: true) but not pushed to GHCR.
#   - The TDLib compilation (~15 min) still runs as part of the build.
#
# GITHUB_TOKEN: required by the GHCR login inside the auth action, which runs in
# both dry-run and default jobs. Generate at https://github.com/settings/tokens
# — scope read:packages is enough for dry-run; write:packages is needed when
# running with dry_run=false to actually push the image.
GITHUB_TOKEN=

# TDLIB_COMMIT: maps to ${{ vars.TDLIB_COMMIT }} in the workflow. Used as the
# docker build-arg and in the tdlib-<commit> image tag. In real CI this is a
# repository variable set under Settings → Secrets and variables → Actions → Variables.
TDLIB_COMMIT=971684a
