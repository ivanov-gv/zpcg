# Environment for testing the release workflow locally with act.
#
# Usage:
#   cp .github/act/release.env.example .github/act/release.env
#   # Fill in all values below, then:
#   make test-ci-release
#
# The Makefile target triggers the workflow via workflow_dispatch (not a v*.*.* tag push),
# passes dry_run=true, and act sets ACT=true, so:
#   - Write operations are skipped.
#   - No images are pushed to GHCR or Artifact Registry.
#   - No Cloud Run deployment is performed (neither preprod nor prod).
# A dry-run summary is printed to the job summary instead.
#
# Note: GitHub environments (preprod/prod) are not simulated by act.
# All three jobs (build-and-push, deploy-to-preprod, deploy-to-prod) use the
# same vars defined in this file.
#
# This file is passed as both --secret-file (for GITHUB_TOKEN and optional
# local auth secrets) and --var-file (for GCLOUD_* vars that map to
# ${{ vars.X }} in the workflow).
#
# GITHUB_TOKEN: Generate at https://github.com/settings/tokens — scope: read:packages
GITHUB_TOKEN=

# Optional local Google auth for read-only Artifact Registry checks in dry-run.
# Prefer GCLOUD_ACCESS_TOKEN for local act:
#   gcloud auth print-access-token
GCLOUD_ACCESS_TOKEN=

# Alternative: minified service account key JSON. Treat this as a password.
# GCLOUD_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Google Cloud configuration — maps to ${{ vars.GCLOUD_* }} in the workflow
GCLOUD_IDENTITY_PROVIDER=projects/<project-number>/locations/global/workloadIdentityPools/<pool>/providers/<provider>
GCLOUD_PROJECT_ID=<gcp-project-id>
GCLOUD_REGION=europe-west1
GCLOUD_SERVICE_ACCOUNT=<service-account>@<project>.iam.gserviceaccount.com
ENVIRONMENT=PREPROD
GCLOUD_RUN_SERVICE=<cloud-run-service-name>
GCLOUD_SECRET_TELEGRAM_APITOKEN_VERSION=projects/<project-id>/secrets/<secret-name>/versions/latest
