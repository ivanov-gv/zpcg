TDLIB_COMMIT=971684a
DEV_REGISTRY=ttl.sh
# Signals to workflows that we're running locally under `act`. Real GitHub never
# defines this var, so production runs are unaffected. Used by job-level `if:`
# guards so test-run jobs are staged correctly even in `act -n` (dry-run), where
# bash steps that would otherwise set this don't execute.
ACT=true