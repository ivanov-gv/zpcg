# Environment for testing the checks workflow locally with act.
#
# Usage:
#   cp .github/act/checks.env.example .github/act/checks.env
#   # Set GITHUB_TOKEN below (required only when dry_run=false to pull the CI container image)
#   make test-ci-checks
#
# With dry_run=true (the Makefile default) only the build job runs — no container pull needed
# and GITHUB_TOKEN can be left empty.
#
# GITHUB_TOKEN: required for test/lint jobs (pulls ghcr.io/ivanov-gv/zpcg/ci:tdlib-<commit>).
# Generate at https://github.com/settings/tokens — required scope: read:packages
GITHUB_TOKEN=

# TDLIB_COMMIT: maps to ${{ vars.TDLIB_COMMIT }} in the workflow. Used to
# resolve the CI container image tag (ci:tdlib-<commit>) and keep test/lint in
# sync with the image built by ci-image.yml. In real CI this is a repository
# variable set under Settings → Secrets and variables → Actions → Variables.
TDLIB_COMMIT=971684a
